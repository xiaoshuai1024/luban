# luban engine E2E 环境变量样例
# 复制为 .env

# 后端预置专用 e2e 账号（MUST：真实登录，替代旧 mock-token）
LUBAN_E2E_ACCOUNT=
LUBAN_E2E_PASSWORD=

# BFF 地址（leads spec 取 siteId 用）
LUBAN_E2E_BFF_URL=http://127.0.0.1:3100

# Playwright baseURL（默认同 vite 端口 4200）
# LUBAN_E2E_BASE_URL=http://127.0.0.1:4200

# CI 无系统 Chrome 时回退
# LUBAN_E2E_USE_PLAYWRIGHT_CHROMIUM=1

# ===== AI 助手（luban-ai-assistant）=====
# AI 服务地址：默认走 vite proxy /ai（→ http://localhost:8000），无需设置。
# 如需前端直连（绕过 proxy），取消注释并指向 AI 服务实际地址：
# VITE_AI_BASE_URL=http://localhost:8000/ai

# FeatureGate（关则隐藏对应能力，编辑器回归原状）：
# VITE_FEATURE_AI_ASSISTANT=false      # 隐藏 AI 助手入口/抽屉（plan P1-T8 回滚）
# VITE_FEATURE_AI_DESIGN_TO_PAGE=false # 隐藏 AI 面板「设计稿」tab（plan P2-T4 回滚）
