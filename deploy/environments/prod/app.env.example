# Copy to app.env on the server (not committed): cp app.env.example app.env
ACME_EMAIL=you@example.com

# Host MySQL/Redis on the same machine as Docker (Linux):
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=luban_prod
MYSQL_USER=luban
MYSQL_PASSWORD=change-me
MYSQL_CHARSET=utf8mb4

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend context path is /backend — Traefik exposes https://api…/healthz → /backend/healthz
