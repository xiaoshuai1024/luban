{
  "name": "luban",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "lint": "eslint . && prettier --check . && stylelint \"**/*.{css,scss,vue}\"",
    "lint:fix": "eslint . --fix && prettier --write . && stylelint \"**/*.{css,scss,vue}\" --fix",
    "depcruise": "depcruise src --config",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ],
    "*.{ts,tsx,vue,css,scss,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.7.7",
    "element-plus": "^2.8.4",
    "luban-low-code": "^0.0.2",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^14.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.1",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss-html": "^1.7.0",
    "prettier": "^3.3.0",
    "sass": "^1.81.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.1",
    "vitest": "^2.1.4",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.1.10",
    "@4tw/cypress-drag-drop": "^2.3.0"
  },
  "pnpm": {
    "overrides": {
      "luban-base": "link:../../ui/luban-ui/packages/luban-base",
      "luban-low-code": "link:../../ui/luban-ui/packages/luban-low-code"
    }
  }
}
